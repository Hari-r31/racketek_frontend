# ─────────────────────────────────────────────────────────────────────────────
# Racketek Frontend — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Razorpay public key (test or live)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# Google OAuth — CLIENT ID only. Get from Google Cloud Console.
# This is safe to expose in the browser (it's used only to render the GSI button).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY: What must NEVER appear here
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_GOOGLE_CLIENT_SECRET  ← NEVER. Secret belongs in backend .env only.
# NEXT_PUBLIC_OAUTH_MOCK            ← NEVER. Mock auth is removed entirely.
# Any private API keys or secrets   ← NEVER. All NEXT_PUBLIC_ vars are public.
